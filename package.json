{
  "name": "seendance-video-workbench",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:web": "vite --host 127.0.0.1",
    "dev:backend": "npm run dev:server",
    "build": "tsc -b && vite build",
    "contract:check": "vitest run tests/apiContract.test.ts tests/apiV1Routes.test.ts",
    "test": "vitest run",
    "server": "tsx server/index.ts",
    "start:backend": "npm run server"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.0",
    "concurrently": "^9.2.1",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "lowdb": "^7.0.1",
    "lucide-react": "^0.554.0",
    "tsx": "^4.20.6",
    "vite": "^7.2.4",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/express": "^5.0.5",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14",
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  }
}
