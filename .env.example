PORT=8787
CORS_ORIGIN=
DATABASE_PATH=data/seendance.json
SQLITE_PATH=data/seendance.sqlite
DOWNLOAD_DIR=data/downloads
UPLOAD_DIR=data/uploads

# Assets API uses Volcengine AK/SK signature auth.
VOLCENGINE_AK=
VOLCENGINE_SK=
VOLCENGINE_REGION=cn-beijing
VOLCENGINE_SERVICE=ark

# Video generation API uses Bearer API key.
ARK_VIDEO_MODEL=ep-20260512140336-qdrjq
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com
IMAGE_HOST_URL=https://uguu.se/upload.php
ASSET_PROJECT_NAME=QiShiYi

# Image generation API uses an OpenAI-compatible chat completions endpoint.
IMAGE2_API_KEY=
IMAGE2_API_URL=https://www.cctq.ai/v1/images/generations
IMAGE2_MODEL=gpt-image-2

POLL_INTERVAL_SECONDS=5
POLL_TIMEOUT_SECONDS=3600
MAX_POLL_RETRY_COUNT=5
MAX_CONCURRENT_VIDEO_TASKS=100
MAX_CONCURRENT_IMAGE_TASKS=8
TOKEN_PRICE_PER_THOUSAND=0.049085
IMAGE_TOKEN_PRICE_PER_THOUSAND=0.049085
